---
// src/pages/dungeon.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Solo Leveling | Weekly Dungeon Tracker">
  <!-- Main Grid Wrapper -->
  <main class="min-h-screen max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col justify-between">
    
    <!-- Header -->
    <header class="border-b border-hairline pb-6 mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div class="space-y-1">
        <div class="flex items-center gap-2">
          <span class="inline-block w-2.5 h-2.5 bg-red-500 rounded-full animate-ping"></span>
          <span class="text-xs font-mono uppercase tracking-widest text-ink-muted">Weekly Consistency Dungeon</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-medium text-white tracking-tight uppercase">
          Weekly Dungeon
        </h1>
      </div>
      
      <!-- Nav & Lock Buttons -->
      <div class="flex items-center gap-3">
        <button 
          id="dungeon-lock-btn" 
          class="inline-flex items-center justify-center font-mono font-bold text-xs uppercase tracking-widest px-4 py-2.5 rounded-full transition-all duration-300 transform active:scale-95 cursor-pointer border border-white/30 text-white hover:bg-white/10 transition-all"
        >
          🔓 GATE: ACTIVE
        </button>
        <a 
          href="/" 
          class="inline-flex items-center justify-center bg-white hover:bg-neutral-200 text-black font-mono font-bold text-xs uppercase tracking-widest px-4 py-2.5 rounded-full transition-all duration-300 transform active:scale-95 cursor-pointer"
        >
          Return to Home
        </a>
      </div>
    </header>

    <!-- System Lock Alert Banner -->
    <div id="dungeon-lock-banner" class="hidden w-full mb-6 p-4 rounded-xl border border-red-500 bg-red-950/20 text-red-400 font-mono text-xs flex items-center justify-between shadow-[0_0_15px_rgba(239,68,68,0.1)]">
      <div class="flex items-center gap-3">
        <span class="text-lg animate-pulse">⚠️</span>
        <div>
          <h3 class="font-bold uppercase tracking-wider text-red-200">System Notification: gate is sealed</h3>
          <p class="text-[10px] text-red-400/80 mt-0.5">Dungeon state is frozen. No quests can be added, modified, completed, or deleted until the gate is unlocked.</p>
        </div>
      </div>
      <button id="dungeon-banner-unlock-btn" class="bg-red-500 hover:bg-red-400 text-black px-3 py-1.5 rounded font-bold uppercase text-[10px] tracking-wider transition-all cursor-pointer active:scale-95">
        Force Unlock
      </button>
    </div>

    <!-- 1. Upper Section: Dungeon Progress Grid (100% width) -->
    <div class="w-full mb-8">
      <!-- Swipe helper for small screens -->
      <div class="block lg:hidden text-right text-[10px] font-mono text-ink-muted/60 mb-2 uppercase tracking-wider select-none animate-pulse">
        ← Swipe grid horizontally to view all days →
      </div>
      <div class="bg-surface-1 border border-hairline rounded-xl p-5 select-none transition-all duration-300 hover:border-ink-muted/30 overflow-x-auto custom-scrollbar">
        <div class="flex items-center justify-between border-b border-hairline pb-3 mb-4 min-w-[600px]">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
            <h2 class="font-display text-lg tracking-wider text-white uppercase">● Dungeon Progress Grid ●</h2>
          </div>
          <div class="flex items-center gap-4 text-xs font-mono">
            <span class="text-ink-muted">Cycle:</span>
            <span id="current-week-range" class="text-white">June 15, 2026 – June 21, 2026</span>
          </div>
        </div>

        <!-- The grid table with complete borders -->
        <table class="w-full min-w-[600px] border border-hairline border-collapse font-mono text-xs text-left" id="weekly-grid-table">
          <thead>
            <tr class="bg-canvas text-ink-muted uppercase tracking-wider text-[10px]">
              <th class="border border-hairline p-3 w-1/4">Quest Objective</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Mon</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Tue</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Wed</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Thu</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Fri</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Sat</th>
              <th class="border border-hairline p-3 text-center w-[60px]">Sun</th>
            </tr>
          </thead>
          <tbody id="weekly-grid-body">
            <!-- Grid rows are populated here -->
            <tr>
              <td colspan="8" class="p-6 text-center text-ink-muted italic border border-hairline">
                Dungeon is currently empty. Configure recurring quests to open cells.
              </td>
            </tr>
          </tbody>
          <tfoot>
            <!-- Completion Percentage Row -->
            <tr class="bg-canvas/50 font-bold text-white">
              <td class="border border-hairline p-3 uppercase text-ink-muted text-[10px]">Completion Rate</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Monday">0%</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Tuesday">0%</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Wednesday">0%</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Thursday">0%</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Friday">0%</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Saturday">0%</td>
              <td class="border border-hairline p-3 text-center font-bold" id="pct-Sunday">0%</td>
            </tr>
            <!-- Day Rank Row -->
            <tr class="bg-canvas/80 font-bold">
              <td class="border border-hairline p-3 uppercase text-ink-muted text-[10px]">Daily Grade</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Monday">E</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Tuesday">E</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Wednesday">E</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Thursday">E</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Friday">E</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Saturday">E</td>
              <td class="border border-hairline p-3 text-center text-sm font-display font-bold" id="rank-Sunday">E</td>
            </tr>
          </tfoot>
        </table>

        <!-- Legend -->
        <div class="mt-4 pt-4 border-t border-hairline/20 flex gap-4 text-[10px] font-mono text-ink-muted min-w-[600px]">
          <span class="font-bold text-white">Legend:</span>
          <div class="flex items-center gap-1">
            <span class="w-5 h-5 rounded border border-hairline bg-canvas/30 flex items-center justify-center text-[10px] font-bold text-ink-muted select-none">□</span>
            <span>Incomplete (□)</span>
          </div>
          <div class="flex items-center gap-1">
            <span class="w-5 h-5 rounded border border-white bg-white/10 text-white flex items-center justify-center text-[10px] font-bold shadow-[0_0_6px_rgba(255,255,255,0.15)]">✓</span>
            <span>Completed (✓)</span>
          </div>
          <div class="flex items-center gap-1">
            <span class="w-5 h-5 rounded border border-red-500 bg-red-950/40 text-red-400 flex items-center justify-center text-[10px] font-bold">✗</span>
            <span>Missed / Penalty (✗)</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Lower Section: Recurring Tasks (Left Column) & Active Objectives (Right Column) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
      
      <!-- Left Column: Recurring Tasks Form & Dungeon Presets -->
      <div class="space-y-6">
        <div class="bg-surface-1 border border-hairline rounded-xl p-5 select-none transition-all duration-300 hover:border-ink-muted/30">
          <div class="flex items-center justify-between border-b border-hairline pb-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              <h2 class="font-display text-lg tracking-wider text-white uppercase">● Recurring Tasks ●</h2>
            </div>
          </div>

          <!-- Add Recurring Task Form -->
          <form id="weekly-add-form" class="space-y-3 p-3 border border-hairline rounded-lg bg-canvas mb-4">
            <div>
              <label for="weekly-text-input" class="block font-mono text-[10px] text-ink-muted uppercase">Task Name</label>
              <input 
                type="text" 
                id="weekly-text-input" 
                required
                placeholder="Workout, Code, Read…" 
                class="bg-surface-2 border border-hairline focus:border-white focus:outline-none rounded-md px-3 py-1.5 font-mono text-xs text-white w-full mt-1"
              />
            </div>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label for="weekly-category-input" class="block font-mono text-[10px] text-ink-muted uppercase">Linked Stat</label>
                <select 
                  id="weekly-category-input"
                  class="bg-surface-2 border border-hairline focus:border-white focus:outline-none rounded-md px-2 py-1.5 font-mono text-xs text-white w-full mt-1"
                >
                  <option value="strength">Attack (STR)</option>
                  <option value="skills">Skills (SKL)</option>
                  <option value="intelligence">Intellect (INT)</option>
                  <option value="willpower" selected>Willpower (WIL)</option>
                  <option value="charisma">Charisma (CHA)</option>
                </select>
              </div>
              <div>
                <label for="weekly-exp-input" class="block font-mono text-[10px] text-ink-muted uppercase">EXP Reward</label>
                <input 
                  type="number" 
                  id="weekly-exp-input"
                  min="5"
                  max="100"
                  value="10"
                  step="5"
                  class="bg-surface-2 border border-hairline focus:border-white focus:outline-none rounded-md px-2 py-1.5 font-mono text-xs text-white w-full mt-1 text-center"
                />
              </div>
            </div>
            <button 
              type="submit" 
              class="w-full bg-white hover:bg-neutral-200 text-black font-mono font-bold text-xs uppercase rounded py-2 cursor-pointer transition-all duration-200 active:scale-95 mt-1"
            >
              Add Weekly Quest
            </button>
          </form>

          <!-- Dungeon Presets (Moved underneath the form) -->
          <div class="border-t border-hairline/25 pt-4 mt-4 space-y-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-1.5">
                <span class="w-1.2 h-1.2 rounded-full bg-white"></span>
                <span class="text-xs font-mono text-white uppercase font-bold tracking-wider">Dungeon Presets</span>
              </div>
              <button 
                type="button" 
                id="toggle-add-template-btn" 
                class="text-[9px] font-mono text-white hover:underline cursor-pointer bg-surface-2 px-2 py-0.5 rounded border border-hairline transition-all"
              >
                + Create Preset
              </button>
            </div>

            <p class="text-[10px] italic text-ink-muted font-mono">
              Click any preset to instantly add it to your weekly recurring objectives.
            </p>

            <!-- Add/Edit Preset Form -->
            <div id="template-editor-panel" class="bg-canvas border border-hairline rounded-lg p-3 hidden space-y-3">
              <h3 id="template-editor-title" class="font-mono text-[9px] text-white uppercase font-bold tracking-wider">New Preset</h3>
              <input type="hidden" id="edit-template-id" />
              <div class="space-y-2">
                <div>
                  <label class="block font-mono text-[9px] text-ink-muted uppercase">Preset Title</label>
                  <input 
                    type="text" 
                    id="template-name-input" 
                    placeholder="Preset Title (e.g. Cardio)" 
                    class="bg-surface-2 border border-hairline text-white rounded px-2 py-1 text-xs w-full focus:outline-none focus:border-white transition-all"
                  />
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div>
                    <label class="block font-mono text-[9px] text-ink-muted uppercase">Category</label>
                    <select 
                      id="template-category-select" 
                      class="bg-surface-2 border border-hairline text-white rounded px-2 py-1 text-xs w-full focus:outline-none"
                    >
                      <option value="strength">Attack</option>
                      <option value="intelligence">Intelligence</option>
                      <option value="willpower">Willpower</option>
                      <option value="charisma">Charisma</option>
                      <option value="skills">Skills</option>
                    </select>
                  </div>
                  <div>
                    <label class="block font-mono text-[9px] text-ink-muted uppercase">EXP</label>
                    <input 
                      type="number" 
                      id="template-exp-input" 
                      placeholder="EXP" 
                      min="5" 
                      value="10"
                      class="bg-surface-2 border border-hairline text-white rounded px-2 py-1 text-xs w-full focus:outline-none"
                    />
                  </div>
                </div>
              </div>
              <div class="flex gap-2 justify-end">
                <button 
                  type="button" 
                  id="cancel-template-btn" 
                  class="bg-transparent hover:bg-surface-2 border border-hairline text-ink-muted px-2 py-0.5 rounded text-[9px] font-mono cursor-pointer transition-all"
                >
                  Cancel
                </button>
                <button 
                  type="button" 
                  id="save-template-btn" 
                  class="bg-white text-black px-2 py-0.5 rounded text-[9px] font-mono font-bold cursor-pointer transition-all"
                >
                  Save
                </button>
              </div>
            </div>

            <!-- Presets list container -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="templates-list-container">
              <!-- Templates will be rendered here dynamically -->
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Active Recurring Objectives List -->
      <div class="space-y-6">
        <div class="bg-surface-1 border border-hairline rounded-xl p-5 select-none transition-all duration-300 hover:border-ink-muted/30">
          <div class="flex items-center justify-between border-b border-hairline pb-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              <h2 class="font-display text-lg tracking-wider text-white uppercase">● Active Objectives ●</h2>
            </div>
            <span id="weekly-count-badge" class="text-xs font-mono text-ink-muted">0 Quests</span>
          </div>

          <p class="text-xs italic text-ink-muted font-mono mb-4">
            These active recurring quests populate the dungeon grid cells above.
          </p>

          <!-- List of active recurring quests -->
          <div id="weekly-quests-list" class="space-y-2 max-h-[450px] overflow-y-auto pr-1 custom-scrollbar">
            <div class="text-center py-8 font-mono text-xs text-ink-muted border border-dashed border-hairline rounded-lg">
              No active weekly recurring quests. Use the presets or form to add quests.
            </div>
          </div>
        </div>
      </div>

    </div>

    </div>

    <!-- Footer -->
    <footer class="mt-12 pt-8 border-t border-hairline flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-mono text-ink-muted">
      <div>
        <span>Dungeon Type: </span>
        <span class="text-white font-bold">WEEKLY_PROGRESSION_INSTANCED</span>
      </div>
      <a 
        href="https://github.com/Zoro-15/to.do.SOLO.leveling" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-ink-muted hover:text-white transition-all flex items-center gap-1.5 focus:outline-none focus-visible:ring-1 focus-visible:ring-white rounded px-1.5 py-0.5"
        aria-label="GitHub Repository"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.1-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.1.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.69 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
        </svg>
        <span>GitHub Repository</span>
      </a>
      <div>
        <span>Accountability: </span>
        <span class="text-red-500 font-bold">STRICT_PENALTY_ACTIVE</span>
      </div>
    </footer>
  </main>
</Layout>

<!-- Client Side Bindings for Weekly Grid -->
<script>
  import {
    loadState,
    saveState,
    addWeeklyTask,
    deleteWeeklyTask,
    editWeeklyTask,
    moveWeeklyTask,
    toggleWeeklyCell,
    getWeekId,
    getMondayOfDate
  } from '../utils/state.js';

  const DAYS = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

  function updateDungeonUI() {
    const stateObj = loadState();
    const weekMondayStr = getWeekId(); // current week monday date YYYY-MM-DD
    const weeklyTasks = stateObj.weeklyTasks;
    const gridData = stateObj.weeklyGrid[weekMondayStr] || {};
    const isLocked = stateObj.dungeonLocked || false;

    // Update range text in header
    const monDate = getMondayOfDate(new Date());
    const sunDate = new Date(monDate);
    sunDate.setDate(monDate.getDate() + 6);
    
    const options = { month: 'short', day: 'numeric', year: 'numeric' };
    const rangeText = `${monDate.toLocaleDateString('en-US', options)} – ${sunDate.toLocaleDateString('en-US', options)}`;
    const rangeEl = document.getElementById('current-week-range');
    if (rangeEl) rangeEl.textContent = rangeText;

    // Update count badge
    const badge = document.getElementById('weekly-count-badge');
    if (badge) badge.textContent = `${weeklyTasks.length} Quest${weeklyTasks.length !== 1 ? 's' : ''}`;

    // Update Gate Lock button and Warning Banner
    const lockBtn = document.getElementById('dungeon-lock-btn');
    const lockBanner = document.getElementById('dungeon-lock-banner');
    
    if (lockBtn) {
      if (isLocked) {
        lockBtn.textContent = '🔒 GATE: LOCKED';
        lockBtn.className = 'inline-flex items-center justify-center font-mono font-bold text-xs uppercase tracking-widest px-4 py-2.5 rounded-full transition-all duration-300 transform active:scale-95 cursor-pointer border bg-red-950/40 text-red-500 border-red-500 hover:bg-red-900/40 shadow-[0_0_10px_rgba(239,68,68,0.2)]';
      } else {
        lockBtn.textContent = '🔓 GATE: ACTIVE';
        lockBtn.className = 'inline-flex items-center justify-center font-mono font-bold text-xs uppercase tracking-widest px-4 py-2.5 rounded-full transition-all duration-300 transform active:scale-95 cursor-pointer border bg-transparent text-white border-white/30 hover:bg-white/10';
      }
    }

    if (lockBanner) {
      if (isLocked) {
        lockBanner.classList.remove('hidden');
      } else {
        lockBanner.classList.add('hidden');
      }
    }

    // Disable / Enable form inputs
    const formInputText = document.getElementById('weekly-text-input') as HTMLInputElement;
    const formInputCat = document.getElementById('weekly-category-input') as HTMLSelectElement;
    const formInputExp = document.getElementById('weekly-exp-input') as HTMLInputElement;
    const formSubmitBtn = document.querySelector('#weekly-add-form button[type="submit"]') as HTMLButtonElement;

    if (formInputText) formInputText.disabled = isLocked;
    if (formInputCat) formInputCat.disabled = isLocked;
    if (formInputExp) formInputExp.disabled = isLocked;
    if (formSubmitBtn) {
      formSubmitBtn.disabled = isLocked;
      if (isLocked) {
        formSubmitBtn.classList.add('opacity-40', 'cursor-not-allowed', 'pointer-events-none');
        formSubmitBtn.classList.remove('hover:bg-neutral-200');
      } else {
        formSubmitBtn.classList.remove('opacity-40', 'cursor-not-allowed', 'pointer-events-none');
        formSubmitBtn.classList.add('hover:bg-neutral-200');
      }
    }

    // Hide preset creation button if locked
    const createPresetBtn = document.getElementById('toggle-add-template-btn');
    if (createPresetBtn) {
      if (isLocked) {
        createPresetBtn.classList.add('hidden');
      } else {
        createPresetBtn.classList.remove('hidden');
      }
    }

    // 1. Render Left Column Quest list
    renderWeeklyQuestsList(weeklyTasks, isLocked);

    // 2. Render Weekly Grid Table
    renderWeeklyGridTable(weeklyTasks, gridData, weekMondayStr, isLocked);

    // 3. Render Presets Panel
    renderPresetsList(stateObj.templates, isLocked);
  }

  function renderWeeklyQuestsList(weeklyTasks, isLocked) {
    const listContainer = document.getElementById('weekly-quests-list');
    if (!listContainer) return;

    if (weeklyTasks.length === 0) {
      listContainer.innerHTML = `
        <div class="text-center py-8 font-mono text-xs text-ink-muted border border-dashed border-hairline rounded-lg">
          No weekly recurring quests. Use the form above to initialize the dungeon.
        </div>
      `;
      return;
    }

    listContainer.innerHTML = '';
    weeklyTasks.forEach((task, idx) => {
      const wrapper = document.createElement('div');
      wrapper.className = "flex gap-2 items-center bg-canvas border border-hairline hover:border-ink-muted/50 p-3 rounded-lg font-mono text-xs justify-between";
      
      const catLabels = {
        strength: 'Attack (STR)',
        skills: 'Skills (SKL)',
        intelligence: 'Intellect (INT)',
        willpower: 'Willpower (WIL)',
        charisma: 'Charisma (CHA)'
      };
      const catLabel = catLabels[task.category] || task.category;

      const isFirst = idx === 0;
      const isLast = idx === weeklyTasks.length - 1;

      wrapper.innerHTML = `
        <div class="flex-1 min-w-0">
          <p class="text-white font-medium truncate">${task.text}</p>
          <p class="text-[9px] text-ink-muted uppercase">${catLabel} • +${task.exp} EXP</p>
        </div>
        ${!isLocked ? `
        <div class="flex gap-1.5 ml-2">
          <button type="button" aria-label="Move objective up" class="move-weekly-up-btn text-white hover:text-neutral-200 text-[10px] bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-2.5 py-1.5 rounded cursor-pointer transition-all min-h-[36px] min-w-[28px] ${isFirst ? 'opacity-25 pointer-events-none' : ''}" title="Move Quest Up">
            ▲
          </button>
          <button type="button" aria-label="Move objective down" class="move-weekly-down-btn text-white hover:text-neutral-200 text-[10px] bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-2.5 py-1.5 rounded cursor-pointer transition-all min-h-[36px] min-w-[28px] ${isLast ? 'opacity-25 pointer-events-none' : ''}" title="Move Quest Down">
            ▼
          </button>
          <button type="button" aria-label="Edit objective" class="edit-weekly-btn text-white hover:text-neutral-200 text-[10px] bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-3 py-1.5 rounded cursor-pointer transition-all ml-1 min-h-[36px]">
            Edit
          </button>
          <button type="button" aria-label="Delete objective" class="delete-weekly-btn text-red-500 hover:text-red-400 text-[10px] bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-3 py-1.5 rounded cursor-pointer transition-all min-h-[36px]">
            Del
          </button>
        </div>
        ` : ''}
      `;

      if (!isLocked) {
        // Event listeners for move up/down
        wrapper.querySelector('.move-weekly-up-btn').addEventListener('click', () => {
          moveWeeklyTask(task.id, 'up');
          updateDungeonUI();
        });

        wrapper.querySelector('.move-weekly-down-btn').addEventListener('click', () => {
          moveWeeklyTask(task.id, 'down');
          updateDungeonUI();
        });

        // Event listener for edit
        wrapper.querySelector('.edit-weekly-btn').addEventListener('click', () => {
          const text = prompt("Edit quest objective description:", task.text);
          if (text !== null && text.trim()) {
            editWeeklyTask(task.id, text.trim(), task.category, task.exp);
            updateDungeonUI();
          }
        });

        // Event listener for delete
        wrapper.querySelector('.delete-weekly-btn').addEventListener('click', () => {
          if (confirm(`Remove "${task.text}" and delete all records for this week?`)) {
            deleteWeeklyTask(task.id);
            updateDungeonUI();
          }
        });
      }

      listContainer.appendChild(wrapper);
    });
  }

  function renderWeeklyGridTable(weeklyTasks, gridData, weekMondayStr, isLocked) {
    const tbody = document.getElementById('weekly-grid-body');
    if (!tbody) return;

    if (weeklyTasks.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="8" class="p-6 text-center text-ink-muted italic border border-hairline bg-surface-1/40">
            Dungeon is currently empty. Configure recurring quests to open cells.
          </td>
        </tr>
      `;
      // Clear tfoot stats
      DAYS.forEach(day => {
        const pctEl = document.getElementById(`pct-${day}`);
        const rankEl = document.getElementById(`rank-${day}`);
        if (pctEl) pctEl.textContent = "0%";
        if (rankEl) {
          rankEl.textContent = "E";
          rankEl.className = "border border-hairline p-3 text-center text-sm font-display text-ink-muted";
        }
      });
      return;
    }

    tbody.innerHTML = '';
    
    // Initialize day counts for rates calculation
    const dailyCompletedCounts = { Monday: 0, Tuesday: 0, Wednesday: 0, Thursday: 0, Friday: 0, Saturday: 0, Sunday: 0 };

    weeklyTasks.forEach((task, idx) => {
      const tr = document.createElement('tr');
      tr.className = "hover:bg-surface-2/20 transition-all group/row";

      const gridRow = gridData[task.id] || {};
      const isFirst = idx === 0;
      const isLast = idx === weeklyTasks.length - 1;

      let cellHtml = `
            <span class="truncate">${task.text}</span>
            ${!isLocked ? `
            <div class="flex items-center gap-1.5 md:opacity-0 md:group-hover/row:opacity-100 transition-all duration-200 shrink-0 flex-wrap">
              <button 
                type="button" 
                aria-label="Move quest up"
                class="move-weekly-row-up-btn text-white hover:text-neutral-200 bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-2.5 py-1.5 md:px-1.5 md:py-0.5 rounded text-[10px] md:text-[9px] font-mono cursor-pointer transition-all min-h-[32px] min-w-[28px] ${isFirst ? 'opacity-25 pointer-events-none' : ''}" 
                data-task-id="${task.id}"
                title="Move quest up"
              >
                ▲
              </button>
              <button 
                type="button" 
                aria-label="Move quest down"
                class="move-weekly-row-down-btn text-white hover:text-neutral-200 bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-2.5 py-1.5 md:px-1.5 md:py-0.5 rounded text-[10px] md:text-[9px] font-mono cursor-pointer transition-all min-h-[32px] min-w-[28px] ${isLast ? 'opacity-25 pointer-events-none' : ''}" 
                data-task-id="${task.id}"
                title="Move quest down"
              >
                ▼
              </button>
              <button 
                type="button" 
                aria-label="Edit quest objective"
                class="edit-weekly-row-btn text-white hover:text-neutral-200 bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-2.5 py-1.5 md:px-1.5 md:py-0.5 rounded text-[10px] md:text-[9px] font-mono cursor-pointer transition-all ml-1 min-h-[32px]" 
                data-task-id="${task.id}"
                title="Edit quest objective"
              >
                ✎
              </button>
              <button 
                type="button" 
                aria-label="Remove quest from dungeon"
                class="delete-weekly-row-btn text-red-500 hover:text-red-400 bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-2.5 py-1.5 md:px-1.5 md:py-0.5 rounded text-[10px] md:text-[9px] font-mono cursor-pointer transition-all min-h-[32px]" 
                data-task-id="${task.id}"
                title="Remove quest from dungeon"
              >
                ✕
              </button>
            </div>
            ` : ''}
          </div>
        </td>
      `;

      DAYS.forEach(day => {
        const status = gridRow[day] || "incomplete";
        if (status === "completed") {
          dailyCompletedCounts[day]++;
        }

        // Squares/Checkboxes instead of circles:
        let innerContent = "";
        let cellClass = "w-9 h-9 sm:w-8 sm:h-8 rounded border border-hairline bg-canvas/30 transition-all duration-200 flex items-center justify-center text-[10px] font-bold text-ink-muted focus-visible:ring-1 focus-visible:ring-white focus:outline-none";
        
        if (!isLocked) {
          cellClass += " hover:border-white cursor-pointer";
        } else {
          cellClass += " cursor-not-allowed opacity-80";
        }
        
        if (status === "completed") {
          innerContent = "✓";
          cellClass = "w-9 h-9 sm:w-8 sm:h-8 rounded border border-white bg-white/10 text-white font-bold text-xs flex items-center justify-center shadow-[0_0_8px_rgba(255,255,255,0.25)] transition-all duration-200 focus-visible:ring-1 focus-visible:ring-white focus:outline-none";
          if (!isLocked) {
            cellClass += " hover:scale-105 cursor-pointer";
          } else {
            cellClass += " cursor-not-allowed opacity-80";
          }
        } else if (status === "missed") {
          innerContent = "✗";
          cellClass = "w-9 h-9 sm:w-8 sm:h-8 rounded border border-red-500 bg-red-950/40 text-red-400 font-bold text-xs flex items-center justify-center shadow-[0_0_8px_rgba(239,68,68,0.3)] transition-all duration-200 focus-visible:ring-1 focus-visible:ring-white focus:outline-none";
          if (!isLocked) {
            cellClass += " hover:scale-105 cursor-pointer";
          } else {
            cellClass += " cursor-not-allowed opacity-80";
          }
        }

        cellHtml += `
          <td class="border border-hairline p-3 text-center">
            <div class="flex items-center justify-center">
              <button 
                type="button" 
                data-task-id="${task.id}" 
                data-day="${day}" 
                aria-label="Cycle status for ${day} on quest: ${task.text}"
                class="weekly-cell-btn ${cellClass}"
                title="${day} status: Click to cycle status"
              >
                ${innerContent}
              </button>
            </div>
          </td>
        `;
      });

      tr.innerHTML = cellHtml;

      if (!isLocked) {
        // Event listener bindings for each cell
        const cellBtns = tr.querySelectorAll('.weekly-cell-btn');
        cellBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const taskId = btn.getAttribute('data-task-id');
            const dayName = btn.getAttribute('data-day');
            if (taskId && dayName) {
              toggleWeeklyCell(weekMondayStr, taskId, dayName);
              updateDungeonUI();
            }
          });
        });

        // Event listeners for moving row up/down directly from the table
        const moveRowUpBtn = tr.querySelector('.move-weekly-row-up-btn');
        if (moveRowUpBtn) {
          moveRowUpBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const taskId = moveRowUpBtn.getAttribute('data-task-id');
            if (taskId) {
              moveWeeklyTask(taskId, 'up');
              updateDungeonUI();
            }
          });
        }

        const moveRowDownBtn = tr.querySelector('.move-weekly-row-down-btn');
        if (moveRowDownBtn) {
          moveRowDownBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const taskId = moveRowDownBtn.getAttribute('data-task-id');
            if (taskId) {
              moveWeeklyTask(taskId, 'down');
              updateDungeonUI();
            }
          });
        }

        // Event listener for editing the row from the table directly
        const editRowBtn = tr.querySelector('.edit-weekly-row-btn');
        if (editRowBtn) {
          editRowBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const taskId = editRowBtn.getAttribute('data-task-id');
            if (taskId) {
              const text = prompt("Edit quest objective description:", task.text);
              if (text !== null && text.trim()) {
                editWeeklyTask(taskId, text.trim(), task.category, task.exp);
                updateDungeonUI();
              }
            }
          });
        }

        // Event listener for deleting the row from the table directly
        const deleteRowBtn = tr.querySelector('.delete-weekly-row-btn');
        if (deleteRowBtn) {
          deleteRowBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const taskId = deleteRowBtn.getAttribute('data-task-id');
            if (taskId && confirm(`Remove "${task.text}" and delete all records for this week?`)) {
              deleteWeeklyTask(taskId);
              updateDungeonUI();
            }
          });
        }
      }

      tbody.appendChild(tr);
    });

    // Update footer cells: completion rate & daily ranks
    const totalQuests = weeklyTasks.length;

    DAYS.forEach(day => {
      const completed = dailyCompletedCounts[day];
      const rate = totalQuests > 0 ? Math.round((completed / totalQuests) * 100) : 0;

      let rank = "E";
      let rankColorClass = "text-ink-muted";
      if (rate >= 90) {
        rank = "S";
        rankColorClass = "text-yellow-400 drop-shadow-[0_0_4px_rgba(250,204,21,0.4)]";
      } else if (rate >= 80) {
        rank = "A";
        rankColorClass = "text-purple-400";
      } else if (rate >= 70) {
        rank = "B";
        rankColorClass = "text-blue-400";
      } else if (rate >= 60) {
        rank = "C";
        rankColorClass = "text-green-400";
      } else if (rate >= 40) {
        rank = "D";
        rankColorClass = "text-white";
      }

      const rateCell = document.getElementById(`pct-${day}`);
      if (rateCell) rateCell.textContent = `${rate}%`;

      const rankCell = document.getElementById(`rank-${day}`);
      if (rankCell) {
        rankCell.textContent = rank;
        rankCell.className = `border border-hairline p-3 text-center text-sm font-display font-bold ${rankColorClass}`;
      }
    });
  }

  // Presets render logic
  function renderPresetsList(templates, isLocked) {
    const container = document.getElementById('templates-list-container');
    if (!container) return;

    if (!templates || templates.length === 0) {
      container.innerHTML = `
        <div class="col-span-2 text-center py-4 font-mono text-[9px] text-ink-muted border border-dashed border-hairline rounded-lg">
          No templates. Click '+ Create Preset' to add.
        </div>
      `;
      return;
    }

    container.innerHTML = '';
    templates.forEach(t => {
      const div = document.createElement('div');
      div.className = "flex items-center gap-1 bg-canvas border border-hairline p-2 rounded font-mono text-[10px] transition-all justify-between group";
      
      if (!isLocked) {
        div.className += " hover:border-white";
      } else {
        div.className += " opacity-60";
      }

      const catLabels = {
        strength: 'Attack',
        skills: 'Skills',
        intelligence: 'Intellect',
        willpower: 'Willpower',
        charisma: 'Charisma'
      };
      const catLabel = catLabels[t.category] || t.category;

      div.innerHTML = `
        <div class="flex-1 min-w-0 ${!isLocked ? 'cursor-pointer add-preset-to-weekly-btn' : 'cursor-not-allowed'}" data-id="${t.id}">
          <p class="text-white font-medium truncate">${t.text}</p>
          <p class="text-[8px] text-ink-muted uppercase">${catLabel} • +${t.exp} EXP</p>
        </div>
        ${!isLocked ? `
        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity ml-1">
          <button type="button" class="edit-preset-btn text-white hover:underline text-[8px] font-mono cursor-pointer" data-id="${t.id}">Edit</button>
          <button type="button" class="delete-preset-btn text-red-500 hover:underline text-[8px] font-mono cursor-pointer" data-id="${t.id}">Del</button>
        </div>
        ` : ''}
      `;

      if (!isLocked) {
        // Quick add recurring task click handler
        div.querySelector('.add-preset-to-weekly-btn').addEventListener('click', () => {
          addWeeklyTask(t.text, t.category, t.exp);
          updateDungeonUI();
        });

        // Edit preset handler
        div.querySelector('.edit-preset-btn').addEventListener('click', (e) => {
          e.stopPropagation();
          showEditPresetForm(t);
        });

        // Delete preset handler
        div.querySelector('.delete-preset-btn').addEventListener('click', (e) => {
          e.stopPropagation();
          if (confirm("Delete this preset template?")) {
            const stateObj = loadState();
            stateObj.templates = stateObj.templates.filter(temp => temp.id !== t.id);
            saveState(stateObj);
            updateDungeonUI();
          }
        });
      }

      container.appendChild(div);
    });
  }

  function showEditPresetForm(template) {
    const panel = document.getElementById('template-editor-panel');
    const titleEl = document.getElementById('template-editor-title');
    const idInput = document.getElementById('edit-template-id') as HTMLInputElement;
    const nameInput = document.getElementById('template-name-input') as HTMLInputElement;
    const categorySelect = document.getElementById('template-category-select') as HTMLSelectElement;
    const expInput = document.getElementById('template-exp-input') as HTMLInputElement;

    if (!panel || !idInput || !nameInput || !categorySelect || !expInput) return;

    titleEl.textContent = "Edit Preset";
    idInput.value = template.id;
    nameInput.value = template.text;
    categorySelect.value = template.category;
    expInput.value = template.exp.toString();

    panel.classList.remove('hidden');
    nameInput.focus();
  }

  // DOM Loaded Event bindings
  document.addEventListener('DOMContentLoaded', () => {
    updateDungeonUI();

    // Lock/Unlock Toggle Handlers
    const lockBtn = document.getElementById('dungeon-lock-btn');
    const bannerUnlockBtn = document.getElementById('dungeon-banner-unlock-btn');

    function toggleDungeonLock() {
      const stateObj = loadState();
      const nextLockedState = !stateObj.dungeonLocked;
      
      const confirmMsg = nextLockedState 
        ? "Warning: Locking the dungeon will freeze all task completions, edits, and deletions for this week. Proceed?" 
        : "Unlock the dungeon gate to allow editing, adding tasks, and toggling completions. Proceed?";
        
      if (confirm(confirmMsg)) {
        stateObj.dungeonLocked = nextLockedState;
        saveState(stateObj);
        updateDungeonUI();
      }
    }

    if (lockBtn) {
      lockBtn.addEventListener('click', toggleDungeonLock);
    }
    if (bannerUnlockBtn) {
      bannerUnlockBtn.addEventListener('click', toggleDungeonLock);
    }

    // Add Quest submit binding
    const form = document.getElementById('weekly-add-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const stateObj = loadState();
        if (stateObj.dungeonLocked) {
          alert("The dungeon is locked. No new quests can be initialized.");
          return;
        }

        const textInput = document.getElementById('weekly-text-input') as HTMLInputElement;
        const catSelect = document.getElementById('weekly-category-input') as HTMLSelectElement;
        const expInput = document.getElementById('weekly-exp-input') as HTMLInputElement;

        if (textInput && catSelect && expInput) {
          const text = textInput.value.trim();
          const category = catSelect.value;
          const exp = parseInt(expInput.value) || 10;

          if (text) {
            addWeeklyTask(text, category, exp);
            textInput.value = '';
            textInput.focus();
            updateDungeonUI();
          }
        }
      });
    }

    // Toggle presets creation panel
    const toggleAddTemplateBtn = document.getElementById('toggle-add-template-btn');
    const templateEditorPanel = document.getElementById('template-editor-panel');
    const cancelTemplateBtn = document.getElementById('cancel-template-btn');
    const saveTemplateBtn = document.getElementById('save-template-btn');

    const templateEditorTitle = document.getElementById('template-editor-title');
    const editTemplateId = document.getElementById('edit-template-id') as HTMLInputElement;
    const templateNameInput = document.getElementById('template-name-input') as HTMLInputElement;
    const templateCategorySelect = document.getElementById('template-category-select') as HTMLSelectElement;
    const templateExpInput = document.getElementById('template-exp-input') as HTMLInputElement;

    if (toggleAddTemplateBtn && templateEditorPanel && cancelTemplateBtn && saveTemplateBtn) {
      toggleAddTemplateBtn.addEventListener('click', () => {
        const stateObj = loadState();
        if (stateObj.dungeonLocked) {
          alert("The dungeon is locked. Presets cannot be configured.");
          return;
        }

        templateEditorTitle.textContent = "New Preset";
        editTemplateId.value = "";
        templateNameInput.value = "";
        templateCategorySelect.value = "willpower";
        templateExpInput.value = "10";

        templateEditorPanel.classList.toggle('hidden');
        if (!templateEditorPanel.classList.contains('hidden')) {
          templateNameInput.focus();
        }
      });

      cancelTemplateBtn.addEventListener('click', () => {
        templateEditorPanel.classList.add('hidden');
      });

      saveTemplateBtn.addEventListener('click', () => {
        const stateObj = loadState();
        if (stateObj.dungeonLocked) {
          alert("The dungeon is locked. Presets cannot be saved.");
          return;
        }

        const text = templateNameInput.value.trim();
        const category = templateCategorySelect.value;
        const exp = parseInt(templateExpInput.value) || 10;
        const editId = editTemplateId.value;

        if (!text) {
          alert("Please enter a title for the template preset.");
          return;
        }

        if (editId) {
          // Edit existing preset
          stateObj.templates = stateObj.templates.map(t => {
            if (t.id === editId) {
              return { ...t, text, category, exp };
            }
            return t;
          });
        } else {
          // Create new preset
          const newTemplate = {
            id: 't-custom-' + Date.now(),
            text,
            category,
            exp
          };
          stateObj.templates.push(newTemplate);
        }

        saveState(stateObj);
        templateEditorPanel.classList.add('hidden');
        updateDungeonUI();
      });
    }
  });
</script>
