---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import HunterPanel from '../components/HunterPanel.astro';
import RankSystemCard from '../components/RankSystemCard.astro';
import ExperienceBar from '../components/ExperienceBar.astro';
import WeeklyDungeonCard from '../components/WeeklyDungeonCard.astro';
import GitHeatmap from '../components/GitHeatmap.astro';
import AnalyticsCard from '../components/AnalyticsCard.astro';
import QuoteCard from '../components/QuoteCard.astro';
---

<Layout title="Solo Leveling | Hunter Status & Quests">
  <!-- Main Grid Wrapper -->
  <main class="min-h-screen max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col justify-between">
    
    <!-- Header -->
    <header class="border-b border-hairline pb-6 mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div class="space-y-1">
        <div class="flex items-center gap-2">
          <span class="inline-block w-2.5 h-2.5 bg-red-500 rounded-full animate-ping"></span>
          <span class="text-xs font-mono uppercase tracking-widest text-ink-muted">Active System Interface</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-medium text-white tracking-tight uppercase">
          Solo Leveling
        </h1>
      </div>
      
      <!-- Date Display and Online Indicator -->
      <div class="flex items-center gap-4 font-mono text-xs">
        <div class="bg-surface-1 border border-hairline rounded px-3 py-1.5 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          <span class="text-ink-muted">LOCAL_DATABASE:</span>
          <span id="current-system-date" class="text-white">June 16, 2026</span>
        </div>
      </div>
    </header>

    <!-- Content Grid (Restructured for better proportions and symmetry) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
      
      <!-- Left Column (col-span-4): Hunter Profile & Heatmap Column -->
      <div class="lg:col-span-4 space-y-6">
        <HunterPanel />
        <GitHeatmap />
        <ExperienceBar />
      </div>

      <!-- Right Column (col-span-8): Dungeon & Quote row, timeline, Today's Active Quests, and Analytics -->
      <div class="lg:col-span-8 space-y-6">
        <!-- Dungeon Preview & Motivation Quote adjacent -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <WeeklyDungeonCard />
          <QuoteCard />
        </div>

        <RankSystemCard />
        
        <!-- Today's Active Quests Card -->
        <div class="bg-surface-1 border border-hairline rounded-xl p-5 select-none transition-all duration-300 hover:border-ink-muted/30">
          <div class="flex items-center justify-between border-b border-hairline pb-3 mb-4">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
              <h2 class="font-display text-lg tracking-wider text-white uppercase">● Today's Active Quests ●</h2>
            </div>
            <span id="daily-count-badge" class="text-xs font-mono text-ink-muted">0 Active</span>
          </div>

          <!-- Add Daily Task Form -->
          <form id="daily-add-form" class="grid grid-cols-1 sm:grid-cols-12 gap-3 mb-4">
            <div class="sm:col-span-6">
              <input 
                type="text" 
                id="daily-text-input" 
                required
                placeholder="Add daily task description…" 
                class="bg-canvas border border-hairline focus:border-white focus:outline-none rounded-md px-3 py-2 font-mono text-xs text-white w-full h-full transition-all"
              />
            </div>
            <div class="sm:col-span-3">
              <select 
                id="daily-category-input"
                class="bg-canvas border border-hairline focus:border-white focus:outline-none rounded-md px-2 py-2 font-mono text-xs text-white w-full h-full transition-all"
              >
                <option value="strength">Attack (STR)</option>
                <option value="skills">Skills (SKL)</option>
                <option value="intelligence">Intellect (INT)</option>
                <option value="willpower" selected>Willpower (WIL)</option>
                <option value="charisma">Charisma (CHA)</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <input 
                type="number" 
                id="daily-exp-input"
                min="5"
                max="100"
                value="10"
                step="5"
                class="bg-canvas border border-hairline focus:border-white focus:outline-none rounded-md px-2 py-2 font-mono text-xs text-white w-full h-full text-center"
                title="EXP Reward"
              />
            </div>
            <div class="sm:col-span-1">
              <button 
                type="submit" 
                class="bg-white hover:bg-neutral-200 text-black font-mono font-bold text-xs uppercase rounded w-full h-full flex items-center justify-center cursor-pointer transition-all active:scale-95 py-2"
                title="Add Task"
              >
                +
              </button>
            </div>
          </form>

          <!-- Quick Presets -->
          <div class="flex flex-wrap gap-1.5 items-center pb-3 mb-4 border-b border-hairline/25 text-[10px] font-mono text-ink-muted">
            <span class="mr-1">Quick Add:</span>
            <button type="button" class="quick-preset-btn px-2 py-0.5 rounded bg-canvas border border-hairline text-white hover:border-white cursor-pointer transition-all" data-text="Daily Workout (100 Reps)" data-cat="strength" data-exp="10">⚔️ Workout</button>
            <button type="button" class="quick-preset-btn px-2 py-0.5 rounded bg-canvas border border-hairline text-white hover:border-white cursor-pointer transition-all" data-text="Study Coding (1 Hour)" data-cat="skills" data-exp="15">💻 Code</button>
            <button type="button" class="quick-preset-btn px-2 py-0.5 rounded bg-canvas border border-hairline text-white hover:border-white cursor-pointer transition-all" data-text="Read 10 Pages of Book" data-cat="willpower" data-exp="10">📖 Read</button>
            <button type="button" class="quick-preset-btn px-2 py-0.5 rounded bg-canvas border border-hairline text-white hover:border-white cursor-pointer transition-all" data-text="Meditation" data-cat="willpower" data-exp="10">🧘 Meditate</button>
          </div>

          <!-- Checklist -->
          <div id="daily-todo-list" class="space-y-2 max-h-[350px] overflow-y-auto pr-1 custom-scrollbar">
            <!-- Dynamically populated daily items -->
            <div class="text-center py-8 font-mono text-xs text-ink-muted border border-dashed border-hairline rounded-lg">
              No quests scheduled for today. Add quests above or click presets to begin your hunter training.
            </div>
          </div>
        </div>

        <AnalyticsCard />
      </div>

    </div>

    </div>

    <!-- Footer -->
    <footer class="mt-12 pt-8 border-t border-hairline flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-mono text-ink-muted">
      <div>
        <span>System Version: </span>
        <span class="text-white font-bold">v2.0.0-UPGRADED</span>
      </div>
      <div>
        <span>Status: </span>
        <span class="text-green-500 font-bold">MONARCH_ACTIVE</span>
      </div>
    </footer>
  </main>
</Layout>

<!-- Client Side State Connection script -->
<script>
  import {
    loadState,
    saveState,
    addDailyTask,
    toggleDailyTask,
    deleteDailyTask,
    editDailyTask,
    getLocalDateString,
    getAnalytics,
    getAchievements,
    getHeatmapData,
    getRankName,
    getRanksList,
    getMondayOfDate,
    getWeekId
  } from '../utils/state.js';

  // State calculations and DOM synchronizer
  function updateUI() {
    const stateObj = loadState();
    const todayStr = getLocalDateString();

    // Calculate dynamic analytics
    const analytics = getAnalytics(stateObj);
    const achievements = getAchievements(stateObj);
    const heatmap = getHeatmapData(stateObj);
    
    // Ranks Order list
    const ranks = getRanksList();
    const hunter = stateObj.hunterData;
    const rankName = getRankName(hunter.rankIndex);

    // ==========================================
    // 1. HUNTER INFO CARD BINDINGS
    // ==========================================
    const nameInput = document.getElementById('hunter-name-input') as HTMLInputElement;
    if (nameInput) nameInput.value = hunter.name;

    const levelEl = document.getElementById('hunter-level');
    if (levelEl) levelEl.textContent = hunter.level.toString();

    // Update class/job depending on rank and level
    let job = "Necromancer";
    if (hunter.level >= 20 || rankName === "Shadow Monarch" || rankName === "National Rank") {
      job = "Shadow Monarch";
    }
    const jobEl = document.getElementById('hunter-job');
    if (jobEl) jobEl.textContent = job;

    const rankEl = document.getElementById('hunter-rank');
    if (rankEl) rankEl.textContent = rankName;

    const titleEl = document.getElementById('hunter-title');
    if (titleEl) titleEl.textContent = hunter.title || "None";

    const expEl = document.getElementById('hunter-exp');
    if (expEl) expEl.textContent = `${hunter.xp} / 100 XP`;

    const hpEl = document.getElementById('hunter-hp');
    if (hpEl) hpEl.textContent = `${hunter.hp} / ${hunter.maxHp}`;

    const hpSolidBar = document.getElementById('hunter-hp-solid-bar');
    if (hpSolidBar) {
      const pct = (hunter.hp / hunter.maxHp) * 100;
      hpSolidBar.style.width = `${pct}%`;
    }

    const avatarRankEl = document.getElementById('hunter-avatar-rank');
    if (avatarRankEl) avatarRankEl.textContent = `Rank ${rankName}`;

    // ==========================================
    // 2. RANK SYSTEM CARD BINDINGS
    // ==========================================
    const rankBadge = document.getElementById('rank-system-badge');
    if (rankBadge) rankBadge.textContent = `Rank ${rankName}`;

    const rankLabel = document.getElementById('current-rank-label');
    if (rankLabel) rankLabel.textContent = rankName;

    const rankCircle = document.getElementById('current-rank-circle');
    if (rankCircle) rankCircle.textContent = rankName.slice(0, 3); // short slice for long rank names

    const rankProgressPct = document.getElementById('rank-progress-percent');
    if (rankProgressPct) rankProgressPct.textContent = `${hunter.rankProgress}%`;

    const rankSolidBar = document.getElementById('rank-solid-bar');
    if (rankSolidBar) rankSolidBar.style.width = `${hunter.rankProgress}%`;

    // Highlight rank nodes in horizontal chain (Squares, no shadow)
    const rankNodeItems = document.querySelectorAll('#rank-ladder-flow [data-rank-node]');
    let foundActive = false;
    rankNodeItems.forEach(item => {
      const nodeRankName = item.getAttribute('data-rank-node');
      const nodeCircle = item.querySelector('div');
      const nodeLabel = item.querySelector('span');

      if (!nodeCircle || !nodeLabel) return;

      if (nodeRankName === rankName) {
        foundActive = true;
        // Node is active: solid white bg, black text, scale up slightly
        nodeCircle.className = "w-8 h-8 rounded border border-white bg-white text-black flex items-center justify-center font-mono font-bold text-xs scale-110 transition-all duration-300";
        nodeLabel.className = "text-[8px] font-mono text-white font-bold";
      } else if (!foundActive) {
        // Passed ranks: white text and white border, canvas bg
        nodeCircle.className = "w-8 h-8 rounded border border-white/60 bg-canvas text-white flex items-center justify-center font-mono font-bold text-xs transition-all duration-300";
        nodeLabel.className = "text-[8px] font-mono text-white/60";
      } else {
        // Future ranks: muted border, muted text, canvas bg
        nodeCircle.className = "w-8 h-8 rounded border border-hairline bg-canvas text-ink-muted flex items-center justify-center font-mono font-bold text-xs transition-all duration-300";
        nodeLabel.className = "text-[8px] font-mono text-ink-muted";
      }
    });

    // ==========================================
    // 3. EXPERIENCE BAR BINDINGS
    // ==========================================
    const expNumeric = document.getElementById('exp-bar-numeric');
    if (expNumeric) expNumeric.textContent = `${hunter.xp} / 100 XP`;

    const expPercent = document.getElementById('exp-bar-percentage');
    if (expPercent) expPercent.textContent = `${hunter.xp}%`;

    const expSolid = document.getElementById('exp-bar-solid');
    if (expSolid) expSolid.style.width = `${hunter.xp}%`;

    const expCurrLvl = document.getElementById('exp-bar-curr-lvl');
    if (expCurrLvl) expCurrLvl.textContent = hunter.level.toString();

    const expNextLvl = document.getElementById('exp-bar-next-lvl');
    if (expNextLvl) expNextLvl.textContent = (hunter.level + 1).toString();

    // ==========================================
    // 4. WEEKLY DUNGEON CARD PREVIEW
    // ==========================================
    const mondayStr = getWeekId();
    const weeklyTasks = stateObj.weeklyTasks;
    const weeklyGrid = stateObj.weeklyGrid[mondayStr] || {};
    
    let weeklyCompleted = 0;
    let weeklyMissed = 0;
    
    weeklyTasks.forEach(t => {
      const gridRow = weeklyGrid[t.id] || {};
      const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
      days.forEach(day => {
        const val = gridRow[day];
        if (val === "completed") weeklyCompleted++;
        else if (val === "missed") weeklyMissed++;
      });
    });

    const totalWeeklyCells = weeklyTasks.length * 7;
    const weeklyPct = totalWeeklyCells > 0 ? Math.round((weeklyCompleted / totalWeeklyCells) * 100) : 0;

    let weeklyRank = "E";
    if (weeklyPct >= 90) weeklyRank = "S";
    else if (weeklyPct >= 80) weeklyRank = "A";
    else if (weeklyPct >= 70) weeklyRank = "B";
    else if (weeklyPct >= 60) weeklyRank = "C";
    else if (weeklyPct >= 40) weeklyRank = "D";

    const previewPctEl = document.getElementById('weekly-preview-percentage');
    if (previewPctEl) previewPctEl.textContent = `${weeklyPct}%`;

    const previewRankEl = document.getElementById('weekly-preview-rank');
    if (previewRankEl) previewRankEl.textContent = `Rank ${weeklyRank}`;

    const previewBar = document.getElementById('weekly-preview-solid-bar');
    if (previewBar) previewBar.style.width = `${weeklyPct}%`;

    // ==========================================
    // 5. ACHIEVEMENT TAGS BINDINGS
    // ==========================================
    const unlockedBadge = document.getElementById('achievements-unlocked-badge');
    if (unlockedBadge) unlockedBadge.textContent = `${achievements.length} / 5 Unlocked`;

    const achTags = document.querySelectorAll('#achievements-list-container [data-achievement-id]');
    achTags.forEach(tag => {
      const id = tag.getAttribute('data-achievement-id');
      const isUnlocked = achievements.some(a => a.id === id);
      if (isUnlocked) {
        tag.className = "flex items-center gap-1 px-2 py-1 rounded border border-white font-mono text-[9px] text-white bg-surface-2 opacity-100 transition-all duration-300";
      } else {
        tag.className = "flex items-center gap-1 px-2 py-1 rounded border border-hairline font-mono text-[9px] text-ink-muted bg-canvas opacity-40 transition-all duration-300";
      }
    });

    // ==========================================
    // 6. ANALYTICS CARD BINDINGS
    // ==========================================
    const analyticsRate = document.getElementById('analytics-rate');
    if (analyticsRate) analyticsRate.textContent = `${analytics.completionRate}%`;

    const analyticsTotal = document.getElementById('analytics-total-quests');
    if (analyticsTotal) analyticsTotal.textContent = `${analytics.completedTasks + analytics.missedTasks} evaluated`;

    const currentStreakEl = document.getElementById('analytics-current-streak');
    if (currentStreakEl) currentStreakEl.textContent = analytics.currentStreak.toString();

    const longestStreakEl = document.getElementById('analytics-longest-streak');
    if (longestStreakEl) longestStreakEl.textContent = analytics.longestStreak.toString();

    const completedEl = document.getElementById('analytics-completed');
    if (completedEl) completedEl.textContent = analytics.completedTasks.toString();

    const missedEl = document.getElementById('analytics-missed');
    if (missedEl) missedEl.textContent = analytics.missedTasks.toString();

    // ==========================================
    // 7. QUOTE BOX BINDINGS
    // ==========================================
    const quoteDisplay = document.getElementById('quote-text-display');
    if (quoteDisplay) quoteDisplay.textContent = `“${hunter.quote}”`;

    const quoteTextarea = document.getElementById('quote-textarea-input') as HTMLTextAreaElement;
    if (quoteTextarea) quoteTextarea.value = hunter.quote;

    // ==========================================
    // 8. GIT HEATMAP BINDINGS
    // ==========================================
    renderHeatmap(heatmap);

    // ==========================================
    // 9. TODAY'S DAILY TASKS RENDER
    // ==========================================
    renderDailyTasksList(stateObj.dailyTasks, todayStr);
  }

  // Render Daily Checklist
  function renderDailyTasksList(tasks, todayStr) {
    const todoContainer = document.getElementById('daily-todo-list');
    if (!todoContainer) return;

    // Filter today's tasks
    const todayTasks = tasks.filter(t => t.dueDate === todayStr);

    const activeCount = todayTasks.filter(t => !t.completed).length;
    const badge = document.getElementById('daily-count-badge');
    if (badge) badge.textContent = `${activeCount} Active`;

    if (todayTasks.length === 0) {
      todoContainer.innerHTML = `
        <div class="text-center py-8 font-mono text-xs text-ink-muted border border-dashed border-hairline rounded-lg">
          No quests scheduled for today. Add quests above or click presets to begin your hunter training.
        </div>
      `;
      return;
    }

    todoContainer.innerHTML = '';
    todayTasks.forEach(task => {
      const wrapper = document.createElement('div');
      wrapper.className = `flex items-center justify-between p-3 rounded-lg border transition-all duration-200 bg-canvas ${
        task.completed 
          ? 'border-hairline-soft opacity-60' 
          : 'border-hairline hover:border-ink-muted/50'
      }`;

      const catLabels = {
        strength: 'Attack (STR)',
        skills: 'Skills (SKL)',
        intelligence: 'Intellect (INT)',
        willpower: 'Willpower (WIL)',
        charisma: 'Charisma (CHA)'
      };
      const catLabel = catLabels[task.category] || task.category;

      wrapper.innerHTML = `
        <div class="flex items-center gap-3 flex-1 min-w-0">
          <button 
            type="button" 
            class="toggle-daily-btn w-5 h-5 rounded border border-white/40 flex items-center justify-center cursor-pointer transition-all hover:border-white focus:outline-none ${
              task.completed ? 'bg-white text-black' : 'bg-transparent text-transparent'
            }"
          >
            <svg class="w-3.5 h-3.5 font-bold" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          </button>
          <div class="flex-1 min-w-0">
            <p class="font-mono text-sm leading-tight text-white truncate ${task.completed ? 'line-through text-ink-muted' : ''}">
              ${task.text}
            </p>
            <span class="text-[9px] font-mono text-ink-muted uppercase block mt-1 select-none">• ${catLabel}</span>
          </div>
        </div>
        <div class="flex items-center gap-2.5 ml-4">
          <span class="text-[10px] font-mono font-bold text-ink bg-surface-2 border border-hairline px-2 py-0.5 rounded select-none">
            +${task.exp} EXP
          </span>
          <div class="flex gap-1">
            <button type="button" class="edit-daily-btn text-white hover:text-neutral-200 text-[9px] font-mono bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-1.5 py-0.5 rounded cursor-pointer transition-all">Edit</button>
            <button type="button" class="delete-daily-btn text-red-500 hover:text-red-400 text-[9px] font-mono bg-surface-2 hover:bg-neutral-900 border border-hairline/25 px-1.5 py-0.5 rounded cursor-pointer transition-all">Del</button>
          </div>
        </div>
      `;

      wrapper.querySelector('.toggle-daily-btn').addEventListener('click', () => {
        toggleDailyTask(task.id);
        updateUI();
      });

      wrapper.querySelector('.edit-daily-btn').addEventListener('click', () => {
        const newText = prompt("Edit quest description:", task.text);
        if (newText !== null && newText.trim()) {
          editDailyTask(task.id, newText.trim(), task.category, task.exp);
          updateUI();
        }
      });

      wrapper.querySelector('.delete-daily-btn').addEventListener('click', () => {
        if (confirm("Delete this quest from today's list?")) {
          deleteDailyTask(task.id);
          updateUI();
        }
      });

      todoContainer.appendChild(wrapper);
    });
  }

  // Render Activity Heatmap (GitHub Colors: Green / Yellowish / Gray)
  function renderHeatmap(heatmapData) {
    const grid = document.getElementById('heatmap-grid');
    if (!grid) return;

    grid.innerHTML = '';
    
    const numWeeks = 10; // 10 columns (7x10 matrix = 70 days)
    const today = new Date();
    const mondayOfThisWeek = getMondayOfDate(today);

    const startDate = new Date(mondayOfThisWeek);
    startDate.setDate(mondayOfThisWeek.getDate() - (numWeeks - 1) * 7);

    const tooltip = document.getElementById('heatmap-tooltip');

    for (let w = 0; w < numWeeks; w++) {
      const col = document.createElement('div');
      col.className = "flex flex-col gap-1 shrink-0";

      for (let d = 0; d < 7; d++) {
        const cellDate = new Date(startDate);
        cellDate.setDate(startDate.getDate() + w * 7 + d);

        const dateStr = getLocalDateString(cellDate);
        const record = heatmapData[dateStr] || { count: 0, xp: 0 };

        const cell = document.createElement('div');
        cell.className = "w-3.5 h-3.5 rounded-[3px] border border-hairline/15 cursor-pointer transition-all hover:scale-125 shrink-0";
        
        // Classic GitHub Green & Light Yellow scale
        let color = "#161b22"; // Level 0 (GitHub empty grid gray-black)
        if (record.count > 0) {
          if (record.count === 1) color = "#0e4429"; // Level 1: Dark Green
          else if (record.count === 2) color = "#006d32"; // Level 2: Medium Green
          else if (record.count === 3) color = "#26a641"; // Level 3: Light Green
          else if (record.count >= 4 || record.xp > 40) color = "#39d353"; // Level 4: Vibrant Green/Yellowish Green
        }
        cell.style.backgroundColor = color;

        cell.addEventListener('mouseover', (e) => {
          if (!tooltip) return;
          const options = { month: 'short', day: 'numeric', year: 'numeric' };
          const formattedDate = cellDate.toLocaleDateString('en-US', options);
          tooltip.innerHTML = `<strong>${formattedDate}</strong><br>${record.count} quest${record.count !== 1 ? 's' : ''} cleared (+${record.xp} EXP)`;
          tooltip.classList.remove('hidden');

          const rect = cell.getBoundingClientRect();
          tooltip.style.left = `${rect.left + window.scrollX - 40}px`;
          tooltip.style.top = `${rect.top + window.scrollY - 50}px`;
        });

        cell.addEventListener('mouseout', () => {
          if (tooltip) tooltip.classList.add('hidden');
        });

        col.appendChild(cell);
      }
      grid.appendChild(col);
    }
  }

  // Setup setup listeners
  document.addEventListener('DOMContentLoaded', () => {
    updateUI();

    // 1. Hunter name edit on blur
    const nameInput = document.getElementById('hunter-name-input') as HTMLInputElement;
    if (nameInput) {
      nameInput.addEventListener('blur', () => {
        const val = nameInput.value.trim();
        if (val) {
          const stateObj = loadState();
          stateObj.hunterData.name = val;
          saveState(stateObj);
          updateUI();
        }
      });
      nameInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') nameInput.blur();
      });
    }

    // 2. Add custom daily quest submit
    const dailyForm = document.getElementById('daily-add-form');
    if (dailyForm) {
      dailyForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const textEl = document.getElementById('daily-text-input') as HTMLInputElement;
        const catEl = document.getElementById('daily-category-input') as HTMLSelectElement;
        const expEl = document.getElementById('daily-exp-input') as HTMLInputElement;

        if (textEl && catEl && expEl) {
          const text = textEl.value.trim();
          const category = catEl.value;
          const exp = parseInt(expEl.value) || 10;

          if (text) {
            addDailyTask(text, category, exp);
            textEl.value = '';
            updateUI();
          }
        }
      });
    }

    // 3. Quick preset buttons click
    const presetBtns = document.querySelectorAll('.quick-preset-btn');
    presetBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-text');
        const cat = btn.getAttribute('data-cat');
        const exp = btn.getAttribute('data-exp');
        if (text && cat && exp) {
          addDailyTask(text, cat, parseInt(exp));
          updateUI();
        }
      });
    });

    // 4. Quote Editor click toggle
    const quoteDisplayContainer = document.getElementById('quote-display-container');
    const quoteEditContainer = document.getElementById('quote-edit-container');
    const quoteTextarea = document.getElementById('quote-textarea-input') as HTMLTextAreaElement;

    if (quoteDisplayContainer && quoteEditContainer && quoteTextarea) {
      quoteDisplayContainer.addEventListener('click', () => {
        quoteDisplayContainer.classList.add('hidden');
        quoteEditContainer.classList.remove('hidden');
        quoteTextarea.focus();
        quoteTextarea.select();
      });

      quoteTextarea.addEventListener('blur', () => {
        const val = quoteTextarea.value.trim();
        if (val) {
          const stateObj = loadState();
          stateObj.hunterData.quote = val;
          saveState(stateObj);
        }
        quoteEditContainer.classList.add('hidden');
        quoteDisplayContainer.classList.remove('hidden');
        updateUI();
      });

      quoteTextarea.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          quoteTextarea.blur();
        }
      });
    }
  });
</script>
