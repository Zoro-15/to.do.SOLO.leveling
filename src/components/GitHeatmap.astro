---
// src/components/GitHeatmap.astro
---

<div class="bg-surface-1 border border-hairline rounded-xl p-5 select-none transition-all duration-300 hover:border-ink-muted/30 w-full relative">
  <!-- Heatmap Tooltip -->
  <div id="heatmap-tooltip" class="absolute pointer-events-none bg-neutral-950 border border-hairline text-[10px] font-mono text-white px-2 py-1 rounded shadow-lg hidden z-50 whitespace-nowrap"></div>

  <div class="flex items-center justify-between border-b border-hairline pb-3 mb-4">
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
      <h2 class="font-display text-lg tracking-wider text-white uppercase">● Shadow Activity Heatmap ●</h2>
    </div>
    <span class="text-xs font-mono text-ink-muted uppercase">Mana tracker</span>
  </div>

  <div class="flex justify-center w-full">
    <!-- Heatmap Grid Container (Centered 7x10 cell matrix) -->
    <div id="heatmap-grid" class="flex gap-1.5 justify-center select-none w-full py-1">
      <!-- Dynamically populated week columns -->
    </div>
  </div>

    <!-- Legend -->
    <div class="flex justify-between items-center text-[10px] font-mono text-ink-muted mt-4">
      <span>Less Activity</span>
      <div class="flex gap-1">
        <span class="w-2.5 h-2.5 rounded-sm bg-[#161b22] border border-hairline/20" title="0 quests"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[#0e4429]" title="1 quest"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[#006d32]" title="2 quests"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[#26a641]" title="3 quests"></span>
        <span class="w-2.5 h-2.5 rounded-sm bg-[#39d353]" title="4+ quests"></span>
      </div>
      <span>More Activity</span>
    </div>
  </div>
</div>
