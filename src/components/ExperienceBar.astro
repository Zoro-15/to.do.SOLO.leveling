---
// src/components/ExperienceBar.astro
---

<div class="bg-surface-1 border border-hairline rounded-xl p-5 select-none transition-all duration-300 hover:border-ink-muted/30 w-full">
  <div class="flex items-center justify-between border-b border-hairline pb-3 mb-4">
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
      <h2 class="font-display text-lg tracking-wider text-white uppercase">● Experience Pool ●</h2>
    </div>
    <span class="text-xs font-mono text-ink-muted uppercase">SYS_LOG: EXP_LEVEL</span>
  </div>

  <div class="space-y-3">
    <div class="flex justify-between items-end">
      <div>
        <span class="text-[10px] font-mono text-ink-muted uppercase block">Next Level Progress</span>
        <span id="exp-bar-numeric" class="font-mono text-sm text-white font-bold">0 / 100 XP</span>
      </div>
      <span id="exp-bar-percentage" class="font-display text-2xl font-bold text-white">0%</span>
    </div>

    <!-- Thick visual progress bar -->
    <div class="w-full bg-canvas border border-hairline rounded-md h-5 p-[2px] overflow-hidden flex items-center">
      <div id="exp-bar-solid" class="bg-white h-full rounded transition-all duration-300" style="width: 0%"></div>
    </div>
    <div class="flex justify-between items-center text-[9px] font-mono text-ink-muted uppercase">
      <span>Lv. <span id="exp-bar-curr-lvl">1</span></span>
      <span>Lv. <span id="exp-bar-next-lvl">2</span></span>
    </div>
  </div>
</div>
