---
// src/components/WeeklyDungeonCard.astro
---

<a href="/dungeon" class="block w-full bg-surface-1 border border-hairline rounded-xl p-4 hover:border-white transition-all duration-300 group select-none">
  <div class="flex items-center justify-between border-b border-hairline pb-2 mb-3">
    <div class="flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
      <h2 class="font-display text-sm tracking-wider text-white uppercase group-hover:text-red-500 transition-colors">● Weekly Dungeon ●</h2>
    </div>
    <span class="text-[9px] font-mono text-ink-muted uppercase border border-hairline bg-canvas px-1.5 py-0.5 rounded">Enter</span>
  </div>

  <div class="flex items-center justify-between gap-3">
    <div class="space-y-1 flex-1 min-w-0">
      <span class="text-[9px] font-mono text-ink-muted uppercase tracking-wider block">Completion</span>
      <div class="w-full bg-canvas border border-hairline rounded-sm h-1.5 p-[1px] overflow-hidden">
        <div id="weekly-preview-solid-bar" class="bg-red-500 h-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>
    <div class="flex items-baseline gap-2 shrink-0">
      <span id="weekly-preview-percentage" class="font-display text-xl font-bold text-white group-hover:text-red-500 transition-colors">0%</span>
      <span id="weekly-preview-rank" class="text-[9px] font-mono text-ink-muted uppercase">Rank E</span>
    </div>
  </div>
</a>
